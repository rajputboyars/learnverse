# Copy to .env.local and fill in.

# MongoDB connection string (local or MongoDB Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/learnverse

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=replace-me
NEXTAUTH_URL=http://localhost:3000

# Comma-separated emails that become admins on registration
ADMIN_EMAILS=admin@learnverse.dev

# Public site URL for SEO (sitemap/robots/canonical/OG). On Vercel use your deployed URL.
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Secret to protect the weekly-XP reset cron endpoint
CRON_SECRET=replace-me
